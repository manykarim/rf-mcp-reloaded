{
  "$defs": {
    "ErrorEnvelope": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Details"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceRecord"
        },
        "retryable": {
          "title": "Retryable",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "suggested_next_step": {
          "minLength": 1,
          "title": "Suggested Next Step",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "severity",
        "provenance",
        "retryable",
        "suggested_next_step"
      ],
      "title": "ErrorEnvelope",
      "type": "object"
    },
    "ProvenanceKind": {
      "enum": [
        "observed",
        "official",
        "curated",
        "provider",
        "inferred"
      ],
      "title": "ProvenanceKind",
      "type": "string"
    },
    "ProvenanceRecord": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "$ref": "#/$defs/ProvenanceKind"
        },
        "provider_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Id"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "source_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        },
        "source_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Path"
        },
        "source_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Type"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "kind",
        "source"
      ],
      "title": "ProvenanceRecord",
      "type": "object"
    },
    "SessionStatus": {
      "enum": [
        "open",
        "closed",
        "interrupted"
      ],
      "title": "SessionStatus",
      "type": "string"
    },
    "SessionSummary": {
      "additionalProperties": false,
      "properties": {
        "attach_host": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attach Host"
        },
        "attach_port": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attach Port"
        },
        "attach_requested": {
          "default": false,
          "title": "Attach Requested",
          "type": "boolean"
        },
        "attach_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attach Token"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "has_possible_closed_shadow_roots": {
          "default": false,
          "title": "Has Possible Closed Shadow Roots",
          "type": "boolean"
        },
        "http_host": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Host"
        },
        "last_error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorEnvelope"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "possible_closed_shadow_root_count": {
          "default": 0,
          "minimum": 0,
          "title": "Possible Closed Shadow Root Count",
          "type": "integer"
        },
        "session_id": {
          "minLength": 1,
          "title": "Session Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/SessionStatus"
        },
        "step_count": {
          "minimum": 0,
          "title": "Step Count",
          "type": "integer"
        },
        "transport": {
          "enum": [
            "stdio",
            "http"
          ],
          "title": "Transport",
          "type": "string"
        },
        "version": {
          "default": 0,
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "session_id",
        "status",
        "transport",
        "created_at",
        "step_count"
      ],
      "title": "SessionSummary",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SnapshotKind": {
      "enum": [
        "app_context",
        "dom",
        "dom_selector",
        "aria",
        "screenshot",
        "console_log",
        "network_log"
      ],
      "title": "SnapshotKind",
      "type": "string"
    },
    "SnapshotManifest": {
      "additionalProperties": false,
      "description": "Pointer to the on-disk snapshot artifact plus a small, kind-specific summary.\n\nThe manifest is always returned. ``content`` on the parent result is only populated\nwhen the caller asks for it explicitly (``return_inline=True``).",
      "properties": {
        "bytes": {
          "description": "Size of the persisted artifact in bytes.",
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "format": {
          "description": "Artifact format: html | html_fragment | yaml | png | json | jsonl | txt.",
          "minLength": 1,
          "title": "Format",
          "type": "string"
        },
        "path": {
          "description": "Repo-relative path to the persisted snapshot artifact (e.g. .rfmcp/snapshots/<sid>/0007_dom.html).",
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "description": "SHA-256 hex digest of the persisted artifact.",
          "maxLength": 64,
          "minLength": 64,
          "title": "Sha256",
          "type": "string"
        },
        "summary": {
          "additionalProperties": true,
          "description": "Kind-specific stats (e.g. title, element_count, role_histogram, status_histogram).",
          "title": "Summary",
          "type": "object"
        }
      },
      "required": [
        "path",
        "bytes",
        "sha256",
        "format"
      ],
      "title": "SnapshotManifest",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Result of an ``app_inspect_state`` capture.\n\n``manifest`` always points at the file on disk. ``content`` is the inline payload\nwhen the caller passed ``return_inline=True``; it is ``None`` otherwise to keep the\nresponse token-cheap. ``truncated`` is ``True`` when ``content`` was capped by the\nper-kind or caller-supplied inline limit.",
  "properties": {
    "content": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content"
    },
    "manifest": {
      "$ref": "#/$defs/SnapshotManifest"
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceRecord"
    },
    "session": {
      "$ref": "#/$defs/SessionSummary"
    },
    "snapshot_kind": {
      "$ref": "#/$defs/SnapshotKind"
    },
    "truncated": {
      "default": false,
      "title": "Truncated",
      "type": "boolean"
    }
  },
  "required": [
    "session",
    "snapshot_kind",
    "provenance",
    "manifest"
  ],
  "title": "InspectionSnapshotResult",
  "type": "object"
}
