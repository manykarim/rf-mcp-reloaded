{
  "$defs": {
    "FailureCategory": {
      "enum": [
        "keyword",
        "library",
        "argument",
        "execution"
      ],
      "title": "FailureCategory",
      "type": "string"
    },
    "HintEntry": {
      "additionalProperties": false,
      "properties": {
        "categories": {
          "items": {
            "$ref": "#/$defs/FailureCategory"
          },
          "title": "Categories",
          "type": "array"
        },
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "error_codes": {
          "items": {
            "type": "string"
          },
          "title": "Error Codes",
          "type": "array"
        },
        "hint_id": {
          "minLength": 1,
          "title": "Hint Id",
          "type": "string"
        },
        "keywords": {
          "items": {
            "type": "string"
          },
          "title": "Keywords",
          "type": "array"
        },
        "libraries": {
          "items": {
            "type": "string"
          },
          "title": "Libraries",
          "type": "array"
        },
        "message_contains": {
          "items": {
            "type": "string"
          },
          "title": "Message Contains",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceRecord"
        },
        "recovery": {
          "minLength": 1,
          "title": "Recovery",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "hint_id",
        "summary",
        "recovery",
        "provenance"
      ],
      "title": "HintEntry",
      "type": "object"
    },
    "ProvenanceKind": {
      "enum": [
        "observed",
        "official",
        "curated",
        "provider",
        "inferred"
      ],
      "title": "ProvenanceKind",
      "type": "string"
    },
    "ProvenanceRecord": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "$ref": "#/$defs/ProvenanceKind"
        },
        "provider_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Id"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "source_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        },
        "source_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Path"
        },
        "source_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Type"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "kind",
        "source"
      ],
      "title": "ProvenanceRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "hints": {
      "items": {
        "$ref": "#/$defs/HintEntry"
      },
      "title": "Hints",
      "type": "array"
    },
    "pack_id": {
      "minLength": 1,
      "title": "Pack Id",
      "type": "string"
    },
    "provider_id": {
      "minLength": 1,
      "title": "Provider Id",
      "type": "string"
    },
    "schema_version": {
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "pack_id",
    "provider_id",
    "version",
    "description"
  ],
  "title": "HintPackManifest",
  "type": "object"
}
