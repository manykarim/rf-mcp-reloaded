{
  "$defs": {
    "DiagnosticFinding": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "$ref": "#/$defs/FailureCategory"
        },
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Details"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceRecord"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "suggested_next_step": {
          "minLength": 1,
          "title": "Suggested Next Step",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "severity",
        "category",
        "provenance",
        "suggested_next_step"
      ],
      "title": "DiagnosticFinding",
      "type": "object"
    },
    "ErrorEnvelope": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Details"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceRecord"
        },
        "retryable": {
          "title": "Retryable",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "suggested_next_step": {
          "minLength": 1,
          "title": "Suggested Next Step",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "severity",
        "provenance",
        "retryable",
        "suggested_next_step"
      ],
      "title": "ErrorEnvelope",
      "type": "object"
    },
    "FailureCategory": {
      "enum": [
        "keyword",
        "library",
        "argument",
        "execution"
      ],
      "title": "FailureCategory",
      "type": "string"
    },
    "FailureContext": {
      "additionalProperties": false,
      "properties": {
        "categories": {
          "items": {
            "$ref": "#/$defs/FailureCategory"
          },
          "title": "Categories",
          "type": "array"
        },
        "error_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Code"
        },
        "failure_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure Message"
        },
        "keyword": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Keyword"
        },
        "libraries": {
          "items": {
            "type": "string"
          },
          "title": "Libraries",
          "type": "array"
        },
        "library": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Library"
        },
        "live_state_available": {
          "default": true,
          "title": "Live State Available",
          "type": "boolean"
        },
        "normalization_conflicts": {
          "items": {
            "type": "string"
          },
          "title": "Normalization Conflicts",
          "type": "array"
        },
        "normalization_events": {
          "items": {
            "type": "string"
          },
          "title": "Normalization Events",
          "type": "array"
        },
        "observed_keywords": {
          "items": {
            "type": "string"
          },
          "title": "Observed Keywords",
          "type": "array"
        },
        "target": {
          "minLength": 1,
          "title": "Target",
          "type": "string"
        },
        "validation_issue_codes": {
          "items": {
            "type": "string"
          },
          "title": "Validation Issue Codes",
          "type": "array"
        }
      },
      "required": [
        "target"
      ],
      "title": "FailureContext",
      "type": "object"
    },
    "HintCandidate": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "hint_id": {
          "minLength": 1,
          "title": "Hint Id",
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceRecord"
        },
        "recovery": {
          "minLength": 1,
          "title": "Recovery",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "hint_id",
        "summary",
        "recovery",
        "provenance"
      ],
      "title": "HintCandidate",
      "type": "object"
    },
    "HintConflict": {
      "additionalProperties": false,
      "properties": {
        "dropped_source": {
          "minLength": 1,
          "title": "Dropped Source",
          "type": "string"
        },
        "hint_id": {
          "minLength": 1,
          "title": "Hint Id",
          "type": "string"
        },
        "kept_source": {
          "minLength": 1,
          "title": "Kept Source",
          "type": "string"
        }
      },
      "required": [
        "hint_id",
        "kept_source",
        "dropped_source"
      ],
      "title": "HintConflict",
      "type": "object"
    },
    "HintPayload": {
      "additionalProperties": false,
      "properties": {
        "candidates": {
          "items": {
            "$ref": "#/$defs/HintCandidate"
          },
          "title": "Candidates",
          "type": "array"
        },
        "error_code": {
          "minLength": 1,
          "title": "Error Code",
          "type": "string"
        }
      },
      "required": [
        "error_code"
      ],
      "title": "HintPayload",
      "type": "object"
    },
    "ProvenanceKind": {
      "enum": [
        "observed",
        "official",
        "curated",
        "provider",
        "inferred"
      ],
      "title": "ProvenanceKind",
      "type": "string"
    },
    "ProvenanceRecord": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "$ref": "#/$defs/ProvenanceKind"
        },
        "provider_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Id"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "source_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        },
        "source_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Path"
        },
        "source_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Type"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "kind",
        "source"
      ],
      "title": "ProvenanceRecord",
      "type": "object"
    },
    "ProviderFailure": {
      "additionalProperties": false,
      "properties": {
        "error": {
          "$ref": "#/$defs/ErrorEnvelope"
        },
        "provider_id": {
          "minLength": 1,
          "title": "Provider Id",
          "type": "string"
        },
        "stage": {
          "minLength": 1,
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "stage",
        "error"
      ],
      "title": "ProviderFailure",
      "type": "object"
    },
    "RecoveryCandidate": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "minLength": 1,
          "title": "Action",
          "type": "string"
        },
        "candidate_id": {
          "minLength": 1,
          "title": "Candidate Id",
          "type": "string"
        },
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceRecord"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "candidate_id",
        "summary",
        "action",
        "provenance"
      ],
      "title": "RecoveryCandidate",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "ValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "column": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column"
        },
        "line": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Line"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        }
      },
      "required": [
        "code",
        "message",
        "severity",
        "path"
      ],
      "title": "ValidationIssue",
      "type": "object"
    },
    "ValidationResult": {
      "additionalProperties": false,
      "properties": {
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorEnvelope"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "issues": {
          "items": {
            "$ref": "#/$defs/ValidationIssue"
          },
          "title": "Issues",
          "type": "array"
        },
        "ok": {
          "title": "Ok",
          "type": "boolean"
        },
        "target": {
          "minLength": 1,
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "ok",
        "target"
      ],
      "title": "ValidationResult",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "context": {
      "$ref": "#/$defs/FailureContext"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorEnvelope"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/DiagnosticFinding"
      },
      "title": "Findings",
      "type": "array"
    },
    "hint": {
      "anyOf": [
        {
          "$ref": "#/$defs/HintPayload"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "hint_conflicts": {
      "items": {
        "$ref": "#/$defs/HintConflict"
      },
      "title": "Hint Conflicts",
      "type": "array"
    },
    "ok": {
      "title": "Ok",
      "type": "boolean"
    },
    "provider_failures": {
      "items": {
        "$ref": "#/$defs/ProviderFailure"
      },
      "title": "Provider Failures",
      "type": "array"
    },
    "recovery_candidates": {
      "items": {
        "$ref": "#/$defs/RecoveryCandidate"
      },
      "title": "Recovery Candidates",
      "type": "array"
    },
    "validation": {
      "$ref": "#/$defs/ValidationResult"
    },
    "verification_mode": {
      "default": "static-fallback",
      "enum": [
        "live-state",
        "static-fallback"
      ],
      "title": "Verification Mode",
      "type": "string"
    }
  },
  "required": [
    "ok",
    "context",
    "validation"
  ],
  "title": "RepairDiagnosticResult",
  "type": "object"
}
