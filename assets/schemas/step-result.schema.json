{
  "$defs": {
    "ErrorEnvelope": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Details"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceRecord"
        },
        "retryable": {
          "title": "Retryable",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "suggested_next_step": {
          "minLength": 1,
          "title": "Suggested Next Step",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "severity",
        "provenance",
        "retryable",
        "suggested_next_step"
      ],
      "title": "ErrorEnvelope",
      "type": "object"
    },
    "ProvenanceKind": {
      "enum": [
        "observed",
        "official",
        "curated",
        "provider",
        "inferred"
      ],
      "title": "ProvenanceKind",
      "type": "string"
    },
    "ProvenanceRecord": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "$ref": "#/$defs/ProvenanceKind"
        },
        "provider_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Id"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "source_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        },
        "source_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Path"
        },
        "source_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Type"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "kind",
        "source"
      ],
      "title": "ProvenanceRecord",
      "type": "object"
    },
    "SessionStatus": {
      "enum": [
        "open",
        "closed",
        "interrupted"
      ],
      "title": "SessionStatus",
      "type": "string"
    },
    "SessionSummary": {
      "additionalProperties": false,
      "properties": {
        "attach_host": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attach Host"
        },
        "attach_port": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attach Port"
        },
        "attach_requested": {
          "default": false,
          "title": "Attach Requested",
          "type": "boolean"
        },
        "attach_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attach Token"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "has_possible_closed_shadow_roots": {
          "default": false,
          "title": "Has Possible Closed Shadow Roots",
          "type": "boolean"
        },
        "http_host": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Host"
        },
        "last_error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorEnvelope"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "possible_closed_shadow_root_count": {
          "default": 0,
          "minimum": 0,
          "title": "Possible Closed Shadow Root Count",
          "type": "integer"
        },
        "session_id": {
          "minLength": 1,
          "title": "Session Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/SessionStatus"
        },
        "step_count": {
          "minimum": 0,
          "title": "Step Count",
          "type": "integer"
        },
        "transport": {
          "enum": [
            "stdio",
            "http"
          ],
          "title": "Transport",
          "type": "string"
        },
        "version": {
          "default": 0,
          "minimum": 0,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "session_id",
        "status",
        "transport",
        "created_at",
        "step_count"
      ],
      "title": "SessionSummary",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "detail": {
      "minLength": 1,
      "title": "Detail",
      "type": "string"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorEnvelope"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "instruction": {
      "minLength": 1,
      "title": "Instruction",
      "type": "string"
    },
    "ok": {
      "title": "Ok",
      "type": "boolean"
    },
    "session": {
      "$ref": "#/$defs/SessionSummary"
    },
    "step_index": {
      "minimum": 1,
      "title": "Step Index",
      "type": "integer"
    }
  },
  "required": [
    "ok",
    "session",
    "step_index",
    "instruction",
    "detail"
  ],
  "title": "StepResult",
  "type": "object"
}
